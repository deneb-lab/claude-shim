{
  "quality-checks": {
    "include": [
      {
        "pattern": "plugins/quality-check-hook/hook/**/*.py",
        "commands": [
          "uv run --project plugins/quality-check-hook/hook ruff format",
          "uv run --project plugins/quality-check-hook/hook ruff check --fix",
          "uv run --project plugins/quality-check-hook/hook ruff check",
          "uv run --project plugins/quality-check-hook/hook pyright --project plugins/quality-check-hook/hook"
        ]
      },
      {
        "pattern": "plugins/github-project-tools/hook/**/*.py",
        "commands": [
          "uv run --project plugins/github-project-tools/hook ruff format",
          "uv run --project plugins/github-project-tools/hook ruff check --fix",
          "uv run --project plugins/github-project-tools/hook ruff check",
          "uv run --project plugins/github-project-tools/hook pyright --project plugins/github-project-tools/hook"
        ]
      },
      {
        "pattern": "**/*.sh",
        "commands": [
          "shellcheck"
        ]
      },
      {
        "pattern": "**/*.{yaml,yml}",
        "commands": [
          "yamllint"
        ]
      },
      {
        "pattern": "**/*.json",
        "commands": [
          "jq ."
        ]
      },
      {
        "pattern": "**/Dockerfile",
        "commands": [
          "hadolint"
        ]
      }
    ],
    "exclude": []
  },
  "github-project-tools": {
    "repo": "deneb-lab/deneb-marketplace",
    "project": "https://github.com/orgs/deneb-lab/projects/1",
    "fields": {
      "start-date": "PVTF_lADOD-Fm1s4BRGlTzg_CVrI",
      "end-date": "PVTF_lADOD-Fm1s4BRGlTzg_CVsc",
      "status": {
        "id": "PVTSSF_lADOD-Fm1s4BRGlTzg_B3r0",
        "todo": [{ "name": "Todo", "option-id": "f75ad846", "default": true }],
        "in-progress": [{ "name": "In Progress", "option-id": "47fc9ee4", "default": true }],
        "done": [{ "name": "Done", "option-id": "98236657", "default": true }]
      },
      "issue-types": [
        { "name": "Task", "id": "IT_kwDOD-Fm1s4B44fF", "default": true },
        { "name": "Bug", "id": "IT_kwDOD-Fm1s4B44fG" }
      ]
    }
  }
}
