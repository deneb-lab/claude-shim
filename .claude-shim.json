{
  "$schema": "https://raw.githubusercontent.com/elahti/claude-shim/main/plugins/quality-check-hook/claude-shim.schema.json",
  "quality-checks": {
    "include": [
      {
        "pattern": "**/*.py",
        "commands": [
          "uv run --project plugins/quality-check-hook/hook ruff format",
          "uv run --project plugins/quality-check-hook/hook ruff check --fix",
          "uv run --project plugins/quality-check-hook/hook ruff check"
        ]
      },
      {
        "pattern": "**/*.sh",
        "commands": [
          "shellcheck"
        ]
      },
      {
        "pattern": "**/*.{yaml,yml}",
        "commands": [
          "yamllint"
        ]
      },
      {
        "pattern": "**/*.json",
        "commands": [
          "jq ."
        ]
      }
    ],
    "exclude": []
  },
  "github-project-tools": {
    "project": "https://github.com/users/elahti/projects/1",
    "fields": {
      "start-date": "PVTF_lAHOAC8LI84BPPkbzg9teuk",
      "end-date": "PVTF_lAHOAC8LI84BPPkbzg9teuo",
      "status": {
        "id": "PVTSSF_lAHOAC8LI84BPPkbzg9tWIc",
        "todo": { "name": "Todo", "option-id": "f75ad846" },
        "in-progress": { "name": "In Progress", "option-id": "47fc9ee4" },
        "done": { "name": "Done", "option-id": "98236657" }
      }
    }
  }
}
