{
  "$defs": {
    "QualityCheckEntry": {
      "properties": {
        "pattern": {
          "title": "Pattern",
          "type": "string"
        },
        "commands": {
          "items": {
            "type": "string"
          },
          "title": "Commands",
          "type": "array"
        }
      },
      "required": [
        "pattern",
        "commands"
      ],
      "title": "QualityCheckEntry",
      "type": "object"
    },
    "QualityChecks": {
      "properties": {
        "include": {
          "items": {
            "$ref": "#/$defs/QualityCheckEntry"
          },
          "title": "Include",
          "type": "array"
        },
        "exclude": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Exclude",
          "type": "array"
        }
      },
      "required": [
        "include"
      ],
      "title": "QualityChecks",
      "type": "object"
    }
  },
  "properties": {
    "quality-checks": {
      "$ref": "#/$defs/QualityChecks",
      "description": "Quality check rules \u2014 which files to match and which commands to run"
    },
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for editor validation"
    }
  },
  "required": [
    "quality-checks"
  ],
  "title": "ClaudeShimConfig",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/elahti/claude-shim/main/plugins/quality-check-hook/claude-shim.schema.json"
}
